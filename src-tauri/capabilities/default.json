{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		{
			"identifier": "shell:allow-execute",
			"allow": [
				{ "name": "zsh", "cmd": "zsh", "args": true },
				{ "name": "claude-code", "cmd": "claude-code", "args": true }
			]
		},
		{
			"identifier": "fs:allow-read-dir",
			"allow": [
				{ "path": "$HOME/**/docs" },
				{ "path": "$HOME/**/docs/**" }
			]
		}
	]
}
