{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Agent Cockpit",
	"version": "0.1.0",
	"identifier": "fr.nextnode.agent-cockpit",
	"build": {
		"beforeDevCommand": "vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Agent Cockpit",
				"width": 1280,
				"height": 800,
				"minWidth": 1024,
				"minHeight": 720
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
